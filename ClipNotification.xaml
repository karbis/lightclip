<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:lightclip"
        x:Class="lightclip.ClipNotification"
        mc:Ignorable="d"
        TextOptions.TextFormattingMode="Display"
        Title="ClipNotification" Height="55" Width="275" Background="Transparent" ResizeMode="NoResize" WindowStyle="None" ShowInTaskbar="False" AllowsTransparency="True" Topmost="True" ShowActivated="False">
    <Grid>
        <Rectangle Stroke="#FF0E212F" Fill="#FF0E2535" RadiusX="7" RadiusY="7" StrokeThickness="2"/>
        <TextBlock Text="Clipped 15 seconds" HorizontalAlignment="Left" VerticalAlignment="Center" Foreground="White" FontSize="16" Padding="8,0,0,0" x:Name="Label">
            <TextBlock.Effect>
                <DropShadowEffect BlurRadius="1" ShadowDepth="1"/>
            </TextBlock.Effect>
        </TextBlock>
        <Button Content="X" HorizontalAlignment="Right" VerticalAlignment="Top" Background="#00DDDDDD" BorderBrush="#00707070" Foreground="#66000000" FontSize="16" FontWeight="Bold" Margin="0,1,6,0" x:Name="CloseButton">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <TextBlock Text="{TemplateBinding Content}" />
                </ControlTemplate>
            </Button.Template>
        </Button>
    </Grid>
</Window>
    