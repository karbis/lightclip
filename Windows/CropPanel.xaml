<UserControl x:Class="lightclip.Windows.CropPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:lightclip.Windows"
             mc:Ignorable="d" 
             d:DesignHeight="611" d:DesignWidth="1086">
    <Canvas Width="1086" Height="611" UseLayoutRounding="True" x:Name="Canvas">
        <Canvas.Resources>
            <RectangleGeometry x:Key="CropRegion" x:Name="CropRegionRectangle" Rect="0,0,1086,611"/>
            <Style TargetType="Button">
                <Setter Property="Template" Value="{StaticResource UnstyledButton}"/>
                <Setter Property="Width" Value="10"/>
                <Setter Property="Height" Value="10"/>
                <Setter Property="Focusable" Value="False"/>
                <Setter Property="IsTabStop" Value="False"/>
                <Setter Property="Background" Value="#C0000000"/>
                <Setter Property="BorderBrush" Value="#FFE6E6E6"/>
            </Style>
        </Canvas.Resources>
        <Path Fill="#80000000">
            <Path.Data>
                <CombinedGeometry GeometryCombineMode="Exclude" Geometry2="{DynamicResource CropRegion}">
                    <CombinedGeometry.Geometry1>
                        <RectangleGeometry Rect="0,0,1086,611" x:Name="ScreenRectangle"/>
                    </CombinedGeometry.Geometry1>
                </CombinedGeometry>
            </Path.Data>
        </Path>
        <Path Stroke="#FFC8C8C8" StrokeDashArray="3" StrokeThickness="1.75" Data="{DynamicResource CropRegion}" x:Name="CropRegionPath" Fill="Transparent"/>
        <Button Canvas.Left="-5" Canvas.Top="-5" x:Name="TopLeftButton"/>
        <Button Canvas.Left="1081" Canvas.Top="-5" x:Name="TopRightButton"/>
        <Button Canvas.Left="-5" Canvas.Top="606" x:Name="BottomLeftButton"/>
        <Button Canvas.Left="1081" Canvas.Top="606" x:Name="BottomRightButton"/>
    </Canvas>
</UserControl>
