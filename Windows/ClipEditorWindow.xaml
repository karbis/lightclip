<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:lightclip.Windows"
        xmlns:lightclip="clr-namespace:lightclip" x:Class="lightclip.Windows.ClipEditorWindow"
        mc:Ignorable="d"
        Title="Clip Editor" Height="720" Width="1280" Icon="/Properties/icon.ico" ShowActivated="True" MinHeight="360" MinWidth="640" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid Background="#FF141618">
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition Height="70"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Background="Black">
                <MediaElement x:Name="VideoElement" LoadedBehavior="Manual">
                    <MediaElement.Effect>
                        <lightclip:DeeperColorEffect/>
                    </MediaElement.Effect>
                </MediaElement>
            </Grid>
            <Grid Grid.Row="1">
                <Grid MaxWidth="1920">
                    <Grid.Resources>
                        <Style TargetType="{x:Type TextBlock}">
                            <Setter Property="Foreground" Value="#FFE6E6E6"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="FontSize" Value="14"/>
                            <Setter Property="Typography.NumeralAlignment" Value="Tabular"/>
                        </Style>
                    </Grid.Resources>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="2.5*" MinWidth="400"/>
                        <ColumnDefinition Width="75"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <Border Height="40" Padding="8,8,8,8" Background="#FF1E2022" CornerRadius="8" HorizontalAlignment="Stretch" Grid.Column="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Grid.Column="0">
                                <Button Template="{StaticResource RoundedButton}" BorderThickness="0" Background="#FF1E2022" x:Name="PlayButton">
                                    <Image Source="/Properties/PlayButton.png" x:Name="PlayButtonImage"/>
                                </Button>
                                <Button Template="{StaticResource RoundedButton}" BorderThickness="0" Background="#FF1E2022" Margin="3,0,0,0" x:Name="VolumeButton">
                                    <Image Source="/Properties/VolumeButton.png"/>
                                </Button>
                                <TextBlock Margin="8,0,0,0" x:Name="PlaybackTimer"><Run Text="0:00.00 / 0:05.00"/></TextBlock>
                                <Popup PlacementTarget="{Binding ElementName=VolumeButton}" Placement="Center" VerticalOffset="-75" AllowsTransparency="True" x:Name="VolumePopup">
                                    <Border Background="#FF1E2022" Width="35" Height="125" CornerRadius="8" Padding="0,8,0,8">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="4*"/>
                                                <RowDefinition Height="1*"/>
                                            </Grid.RowDefinitions>
                                            <Slider Grid.Row="0" Orientation="Vertical" HorizontalAlignment="Center" Minimum="0" Maximum="100" SmallChange="1" x:Name="VolumeSlider"/>
                                            <TextBlock Grid.Row="1" HorizontalAlignment="Center" FontSize="14" Margin="0,4,0,0" Text="{Binding Value, ElementName=VolumeSlider, StringFormat=\{0:0\}}"/>
                                        </Grid>
                                    </Border>
                                </Popup>
                            </StackPanel>
                            <Grid Grid.Column="1" Margin="18,0,18,0" x:Name="SkimBar" ClipToBounds="False" Background="Transparent">
                                <Border HorizontalAlignment="Stretch" VerticalAlignment="Center" Height="5" Background="#FF3C3E40" x:Name="TrimBarBg"/>
                                <Border HorizontalAlignment="Left" Width="100" Background="#FF3C82B4" Height="5" x:Name="TrimBar"/>
                                <Border Width="12" Height="12" VerticalAlignment="Center" Background="#FF3C82B4" ClipToBounds="False" CornerRadius="100" HorizontalAlignment="Left" Margin="95,0,0,0" x:Name="TrimBarCircle"/>
                                <Border HorizontalAlignment="Left" Width="8" Height="20" Background="#FF1F577F" Margin="-20,0,0,0" CornerRadius="2" x:Name="TrimMinBar"/>
                                <Border HorizontalAlignment="Left" Width="8" Height="20" Background="#FF1F577F" Margin="410,0,-8,0" CornerRadius="2" x:Name="TrimMaxBar"/>
                            </Grid>
                            <TextBlock Grid.Column="2" x:Name="TrimLength"><Run Text="0:05.00"/></TextBlock>
                        </Grid>
                    </Border>
                    <Button Grid.Column="2" Height="35" Template="{StaticResource RoundedButton}" Margin="10,0,0,0" FontSize="14" BorderThickness="1" BorderBrush="#FF0E2535" Background="#FF245F8A" Foreground="#FFE6E6E6" Content="Save" x:Name="SaveButton"/>
                </Grid>
            </Grid>
        </Grid>
        <Border Background="#59000000" Visibility="Collapsed" x:Name="ProcessingOverlay">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Foreground="White" VerticalAlignment="Top" HorizontalAlignment="Center" FontSize="20" Text="Processing.."/>
                <Border HorizontalAlignment="Center" Width="500" VerticalAlignment="Center" Height="7" Background="#FF3C3E40" Grid.Column="1" Margin="0,7,0,0" BorderThickness="1" BorderBrush="#FF282A2C">
                    <Border HorizontalAlignment="Left" Background="#FF3C82B4" Width="100" x:Name="ProcessingBar"/>
                </Border>
                <TextBlock Foreground="White" VerticalAlignment="Top" HorizontalAlignment="Center" FontSize="16" Text="99%" Margin="0,1,0,0" x:Name="ProcessingText"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
